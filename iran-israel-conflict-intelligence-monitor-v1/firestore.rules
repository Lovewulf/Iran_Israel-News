rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: articles
    // Fields:
    //   - title: string (required)
    //   - content: string (required)
    //   - summary: string (optional)
    //   - url: string (required, format: uri)
    //   - source_name: string (required)
    //   - source_type: string (required, enum: ['rss', 'news_api', 'youtube', 'manual'])
    //   - published_at: timestamp (required)
    //   - ingested_at: timestamp (required)
    //   - category_id: string (optional)
    //   - tag_ids: list (required, size < 50)
    //   - is_breaking: bool (required)
    //
    // Collection: ai_reports
    // Fields:
    //   - title: string (required)
    //   - summary: string (optional)
    //   - type: string (required, enum: ['daily', 'weekly', 'flash', 'strategic'])
    //   - content: string (required)
    //   - generated_at: timestamp (required)
    //   - source_article_ids: list (required, size < 100)
    //   - is_verified: bool (required)
    //
    // Collection: event_clusters
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - start_date: timestamp (required)
    //   - status: string (required, enum: ['active', 'resolved', 'archived'])
    //   - article_ids: list (required, size < 1000)
    //   - impact_level: number (required, 1-5)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ashirazk60@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, maxLen) {
      return request.resource.data[field] is string && request.resource.data[field].size() <= maxLen;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*") || url.matches("^internal://.*"));
    }

    function isValidList(list, maxSize) {
      return list is list && list.size() <= maxSize;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidArticle(data) {
      return hasRequiredFields(['title', 'content', 'url', 'source_name', 'source_type', 'published_at', 'ingested_at', 'tag_ids', 'is_breaking', 'fingerprint', 'first_seen_at', 'last_updated_at']) &&
             isValidString('title', 1000) &&
             isValidString('fingerprint', 256) &&
             isValidUrl(data.url) &&
             data.published_at is timestamp &&
             (data.ingested_at is timestamp || data.ingested_at == null) &&
             data.first_seen_at is timestamp &&
             data.last_updated_at is timestamp &&
             isValidList(data.tag_ids, 50);
    }

    function isValidReport(data) {
      return hasRequiredFields(['title', 'type', 'content', 'generated_at', 'source_article_ids', 'is_verified']) &&
             data.type in ['daily', 'weekly', 'flash', 'strategic'] &&
             isValidString('title', 1000) &&
             data.generated_at is timestamp &&
             isValidList(data.source_article_ids, 100) &&
             data.is_verified is bool;
    }

    function isValidEventCluster(data) {
      return hasRequiredFields(['title', 'description', 'start_date', 'status', 'article_ids', 'impact_level']) &&
             isValidString('title', 1000) &&
             isValidString('description', 5000) &&
             data.start_date is timestamp &&
             data.status in ['active', 'resolved', 'archived'] &&
             isValidList(data.article_ids, 1000) &&
             data.impact_level is number && data.impact_level >= 1 && data.impact_level <= 5;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /articles/{articleId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidArticle(request.resource.data);
      allow delete: if isAdmin();
    }

    match /ai_reports/{reportId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidReport(request.resource.data);
      allow delete: if isAdmin();
    }

    match /event_clusters/{clusterId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidEventCluster(request.resource.data);
      allow delete: if isAdmin();
    }

    match /sources/{sourceId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /diagnostics/{diagId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /_internal_/connectivity_test {
      allow read: if true;
    }

    match /settings/{settingId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAuthenticated() && request.auth.uid == userId && 
                             (!('role' in request.resource.data) || request.resource.data.role == resource.data.role || isAdmin());
    }
  }
}
